  "custom": false,
  "title": {
    "en": "Getting Dressed—A Woman",
    "zh": "穿衣服——女士"
  },
  "tense": "Simple Present",
  "level": 2,
  "phrases": [
    {
      "en": "Pam puts on some panties.",
      "zh": "帕姆穿上内裤。"
    },
    {
      "en": "A bra.",
      "zh": "穿上文胸。"
    },
    {
      "en": "A dress.",
      "zh": "穿上连衣裙。"
    },
    {
      "en": "A blouse / a shirt.",
      "zh": "一件女衬衫／衬衫。"
    },
    {
      "en": "A skirt.",
      "zh": "一条裙子。"
    },
    {
      "en": "Some pants.",
      "zh": "一条裤子。"
    },
    {
      "en": "Some socks.",
      "zh": "一些袜子。"
    },
    {
      "en": "Some nylons (stockings).",
      "zh": "一些尼龙袜（长筒袜）。"
    },
    {
      "en": "Some pantyhose.",
      "zh": "一条连裤袜。"
    },
    {
      "en": "After you put on your clothes, you wear them.",
      "zh": "你穿上衣服后，就把它们穿在身上。"
    },
    {
      "en": "These people are wearing suits.",
      "zh": "这些人穿着西装。"
    },
    {
      "en": "These people are wearing casual clothes.",
      "zh": "这些人穿着休闲服。"
    },
    {
      "en": "If it's hot, Pam wears light clothes.",
      "zh": "如果天气热，帕姆就穿轻薄的衣服。"
    },
    {
      "en": "A short-sleeved cotton shirt.",
      "zh": "一件短袖棉衬衫。"
    },
    {
      "en": "And a pair of cotton shorts.",
      "zh": "再加一条棉短裤。"
    },
    {
      "en": "She goes barefoot indoors.",
      "zh": "她在室内光着脚。"
    },
    {
      "en": "And wears sandals outdoors.",
      "zh": "在室外穿凉鞋。"
    },
    {
      "en": "Dressing this way keeps her cool.",
      "zh": "这样穿能让她保持凉爽。"
    },
    {
      "en": "If it's cold, Pam wears heavy clothes.",
      "zh": "如果天气冷，帕姆就穿厚衣服。"
    },
    {
      "en": "A long-sleeved shirt.",
      "zh": "一件长袖衬衫。"
    },
    {
      "en": "A wool sweater.",
      "zh": "一件羊毛毛衣。"
    },
    {
      "en": "Long pants.",
      "zh": "长裤。"
    },
    {
      "en": "And thick wool socks.",
      "zh": "再加一双厚羊毛袜。"
    },
    {
      "en": "Before going outdoors, she puts on a heavy coat.",
      "zh": "出门前，她穿上一件厚外套。"
    },
    {
      "en": "And some gloves or mittens.",
      "zh": "再戴上手套或连指手套。"
    },
    {
      "en": "She wraps a scarf around her neck.",
      "zh": "她在脖子上围一条围巾。"
    },
    {
      "en": "And puts on a hat.",
      "zh": "再戴上一顶帽子。"
    },
    {
      "en": "And some boots.",
      "zh": "再穿上靴子。"
    },
    {
      "en": "Dressing this way keeps her warm.",
      "zh": "这样穿能让她保暖。"
    }
  ]
}
