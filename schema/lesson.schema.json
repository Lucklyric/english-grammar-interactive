{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["id","slug","category","shape","order","title","summary","source","concepts","examples","quizzes","dialogue"],
  "properties": {
    "id": { "type": "string", "pattern": "^[0-9]{2}$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "category": { "type": "string" },
    "shape": { "enum": ["tiny","standard","deep-dive"] },
    "order": { "type": "integer" },
    "title": { "$ref": "#/$defs/biling" },
    "summary": { "$ref": "#/$defs/biling" },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["videoId","youtube","duration","script"],
      "properties": {
        "videoId": { "type": "string" }, "youtube": { "type": "string" },
        "duration": { "type": "string" }, "script": { "type": "string" }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id","label","abbr","color","underline"],
        "properties": {
          "id": { "type": "string" }, "label": { "$ref": "#/$defs/biling" },
          "abbr": { "type": "string" }, "color": { "type": "string" },
          "underline": { "enum": ["solid","dashed","dotted"] }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id","heading","body"],
        "properties": {
          "id": { "type": "string" }, "heading": { "$ref": "#/$defs/biling" },
          "body": { "$ref": "#/$defs/biling" },
          "exampleRefs": { "type": "array", "items": { "type": "string" } },
          "sourceRef": { "type": "string" }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id","text","annotations"],
        "properties": {
          "id": { "type": "string" }, "text": { "type": "string" },
          "annotations": { "type": "array", "items": { "$ref": "#/$defs/annotation" } },
          "note": { "$ref": "#/$defs/biling" }
        }
      }
    },
    "quizzes": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "object", "additionalProperties": false,
            "required": ["id","type","prompt","choices","answer","explain"],
            "properties": {
              "id": { "type": "string" }, "type": { "const": "mcq" },
              "prompt": { "$ref": "#/$defs/biling" },
              "choices": { "type": "array", "minItems": 2, "items": {
                "type": "object", "additionalProperties": false,
                "required": ["id","text"],
                "properties": { "id": { "type": "string" }, "text": { "$ref": "#/$defs/biling" } } } },
              "answer": { "type": "string" }, "explain": { "$ref": "#/$defs/biling" },
              "refs": { "type": "array", "items": { "type": "string" } } } },
          { "type": "object", "additionalProperties": false,
            "required": ["id","type","prompt","answers","explain"],
            "properties": {
              "id": { "type": "string" }, "type": { "const": "fill" },
              "prompt": { "$ref": "#/$defs/biling" },
              "answers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "explain": { "$ref": "#/$defs/biling" },
              "refs": { "type": "array", "items": { "type": "string" } } } },
          { "type": "object", "additionalProperties": false,
            "required": ["id","type","sentence","fix","explain"],
            "properties": {
              "id": { "type": "string" }, "type": { "const": "error" },
              "sentence": { "type": "string" }, "fix": { "type": "string" },
              "explain": { "$ref": "#/$defs/biling" },
              "refs": { "type": "array", "items": { "type": "string" } } } }
        ]
      }
    },
    "dialogue": {
      "type": "object", "additionalProperties": false,
      "required": ["kind","title","targets","lines"],
      "properties": {
        "kind": { "enum": ["dialogue","scenario"] },
        "title": { "$ref": "#/$defs/biling" },
        "targets": { "type": "array", "items": { "type": "string" } },
        "lines": { "type": "array", "minItems": 1, "items": {
          "type": "object", "additionalProperties": false,
          "required": ["speaker","text"],
          "properties": {
            "speaker": { "type": "string" }, "text": { "type": "string" },
            "annotations": { "type": "array", "items": { "$ref": "#/$defs/annotation" } },
            "note": { "$ref": "#/$defs/biling" } } } }
      }
    }
  },
  "$defs": {
    "biling": { "type": "object", "additionalProperties": false,
      "required": ["en","zh"], "properties": { "en": { "type": "string", "minLength": 1 }, "zh": { "type": "string", "minLength": 1 } } },
    "annotation": { "type": "object", "additionalProperties": false,
      "required": ["quote","tag"],
      "properties": { "quote": { "type": "string", "minLength": 1 }, "tag": { "type": "string" }, "occurrence": { "type": "integer", "minimum": 1 } } }
  }
}
